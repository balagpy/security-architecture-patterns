flowchart LR
    subgraph Internet[Untrusted Network]
        C[Client App]
        ATT[Attacker Replay Client]
    end

    subgraph Edge[Edge Trust Zone]
        GW[API Gateway]
    end

    subgraph App[Service Trust Zone]
        A1[Service Instance A]
        A2[Service Instance B]
        A3[Service Instance C]
        LC1[(Local Revocation Cache A)]
        LC2[(Local Revocation Cache B)]
        LC3[(Local Revocation Cache C)]
        A1 --> LC1
        A2 --> LC2
        A3 --> LC3
    end

    subgraph Identity[Identity Control Plane]
        IDP[Auth Service / IdP]
    end

    subgraph Data[State Plane]
        R[(Redis Revocation Store)]
        PUB[(Event Bus / PubSub)]
    end

    C --> GW
    GW --> A1
    GW --> A2
    GW --> A3

    IDP --> R
    IDP --> PUB

    A1 --> R
    A2 --> R
    A3 --> R
    PUB -. invalidation fan-out .-> A1
    PUB -. invalidation fan-out .-> A2
    PUB -. invalidation fan-out .-> A3

    ATT --> GW
